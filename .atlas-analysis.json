  "keyFeatures": [
    "One-line platform switching between Discord, Slack, Teams, and Google Chat",
    "Unified API for sending messages, handling events, and managing reactions",
    "Full TypeScript support with intelligent type inference",
    "Platform-agnostic bot logic with progressive disclosure of complexity",
    "Monorepo architecture with tree-shakeable platform adapters",
    "Result type pattern for robust error handling"
  ],
  "publicApiSurface": [
    "createBot(config: BotConfig): Bot",
    "Bot.start(): Promise<void>",
    "Bot.stop(): Promise<void>",
    "Bot.sendMessage(channelId: string, text: string, options?: SendMessageOptions): Promise<Result<UnifiedMessage>>",
    "Bot.reply(message: UnifiedMessage, text: string, options?: SendMessageOptions): Promise<Result<UnifiedMessage>>",
    "Bot.editMessage(messageRef: MessageRef, newText: string): Promise<Result<UnifiedMessage>>",
    "Bot.deleteMessage(messageRef: MessageRef): Promise<Result<void>>",
    "Bot.addReaction(messageRef: MessageRef, emoji: string): Promise<Result<void>>",
    "Bot.removeReaction(messageRef: MessageRef, emoji: string): Promise<Result<void>>",
    "Bot.createThread(messageRef: MessageRef, text: string): Promise<Result<UnifiedMessage>>",
    "Bot.uploadFile(channelId: string, file: unknown, options?: UploadOptions): Promise<Result<UnifiedMessage>>",
    "Bot.getChannels(): Promise<Result<Channel[]>>",
    "Bot.getUsers(channelId?: string): Promise<Result<User[]>>",
    "Bot.onMessage(handler: MessageHandler): void",
    "Bot.onReaction(handler: (event: ReactionEvent) => void | Promise<void>): void",
    "Bot.onEvent(handler: (event: UnifiedEvent) => void | Promise<void>): void",
    "ok<T>(value: T): Result<T>",
    "err(error: Error): Result<never>",
    "wrapAsync<T>(fn: () => Promise<T>): Promise<Result<T>>",
    "isOk<T>(result: Result<T>): boolean",
    "isErr<T>(result: Result<T>): boolean"
  ]
}
